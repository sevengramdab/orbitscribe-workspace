# OrbitScribe Swarm Backend Configuration

# API Mode: local_only | cloud_only | hybrid
# When SUBAGENT_MODE=local and SWARM_API_MODE is not set, API_MODE defaults to local_only.
SWARM_API_MODE=hybrid

# Backend port
SWARM_PORT=58081

# Subagent spawning mode: cloud | local | hybrid
# Set to "local" to route ALL LLM calls to Ollama via its OpenAI-compatible endpoint.
SUBAGENT_MODE=hybrid

# Gemini API key (required for cloud mode)
GEMINI_API_KEY=

# OpenAI / Kimi API key (required for cloud mode or third-party OpenAI-compatible APIs)
OPENAI_API_KEY=
KIMI_API_KEY=

# OpenAI-compatible base URL (optional — for custom providers like Groq, Azure, etc.)
OPENAI_BASE_URL=

# Ollama native API URL
OLLAMA_URL=http://127.0.0.1:11434

# Ollama OpenAI-compatible API URL (used when SUBAGENT_MODE=local)
OLLAMA_OPENAI_URL=http://localhost:11434/v1

# LM Studio URL
LMSTUDIO_URL=http://127.0.0.1:1234

# Local models
LOCAL_FAST_MODEL=llama3.1:8b
LOCAL_COMPLEX_MODEL=qwen3:14b
LOCAL_MODEL=llama3.1:8b

# Cloud / orchestrator models
CLOUD_MODEL=gemini-2.0-flash
ORCHESTRATOR_MODEL=gemini-2.0-flash
