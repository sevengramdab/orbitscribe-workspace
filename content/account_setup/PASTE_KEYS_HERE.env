# =============================================================================
# PASTE YOUR API KEYS & ACCOUNT INFO BELOW
# After pasting, run:  python tools/ingest_account_keys.py
# =============================================================================

# =============================================================================
# MEDIUM  ⚠️  READ THIS FIRST
# =============================================================================
# MEDIUM STOPPED ISSUING NEW INTEGRATION TOKENS ON JAN 1, 2025.
# If you do NOT already have a token from before 2025, you CANNOT get one.
#
# WHERE TO CHECK (in case you have an old one):
#   Direct link: https://medium.com/me/settings
#   - Scroll to the VERY BOTTOM of the page.
#   - Look for tiny text link "Integration tokens"
#   - If it exists, click it → "Get token" → copy the long string.
#   - If it does NOT exist, Medium has locked you out of API access.
#
# WHAT THIS MEANS FOR PUBLISHING:
#   - We CANNOT auto-post to Medium via API.
#   - We WILL use manual copy-paste publishing instead.
#   - The tool formats articles as Medium-ready HTML for you to paste.
#
# ALTERNATIVE (paid): https://mediumapi.com via RapidAPI (150 req/mo free)
#   Only worth it if you're doing high-volume cross-posting.
# =============================================================================
MEDIUM_API_TOKEN="LEAVE_BLANK_IF_NO_OLD_TOKEN"
MEDIUM_USER_ID="PASTE_HERE"  # Your @username, e.g. @joshua-dyer

# =============================================================================
# SUBSTACK
# =============================================================================
# NO API TOKEN NEEDED. Substack publishing is done via web/email.
# I already see your info from the browser — just confirming:
#
# Direct link to your publication: https://substack.com/@orbstudio
# Direct link to write a post:    https://substack.com/write
# Direct link to settings:        https://substack.com/settings
#
# For paid subscriptions, connect Stripe here:
#   https://substack.com/settings → "Payments" tab → Connect Stripe
# =============================================================================
SUBSTACK_URL=https://substack.com/@orbstudio
SUBSTACK_PUBLICATION_NAME="OrbStudio's Substack"
SUBSTACK_FROM_EMAIL=joshldyer@gmail.com

# =============================================================================
# CLICKBANK
# =============================================================================
# I saw your dashboard — you're logged in as "joshua dyer".
# Here are the EXACT steps to find what we need:
#
# --- ACCOUNT NICKNAME (needed for HopLinks) ---
#   Direct link: https://accounts.clickbank.com/master/account/profile.htm
#   OR: Click "Profile" in left sidebar → look for "Account Nickname"
#   It looks like: joshua123, jdtech, orbstudio, etc.
#   This goes in your HopLinks: https://NICKNAME.cbfeed.com/?id=PRODUCT
#
# --- API KEYS (for automated product lookups) ---
#   Step 1: Go to https://accounts.clickbank.com/master/account/profile.htm
#   Step 2: Click the "Account Settings" tab (next to "Profile Information")
#   Step 3: Scroll down to "API Keys" or "Developer" section
#   Step 4: Copy: Developer Key, API Secret, Client ID, Client Secret
#
#   NOTE: If the account is brand new, you may need to click
#   "Complete Profile" on the dashboard before API access unlocks.
#
# --- TRACKING IDs (optional, for campaign tracking) ---
#   In your ClickBank account → Accounts → Your Nickname
#   → "Tracking IDs" → Create ID (e.g., BLOG1, EMAIL1)
# =============================================================================
CLICKBANK_ACCOUNT_NICKNAME="PASTE_HERE"     # From Profile page
CLICKBANK_DEVELOPER_KEY="PASTE_HERE"        # Account Settings → API
CLICKBANK_API_SECRET="PASTE_HERE"           # Account Settings → API
CLICKBANK_CLIENT_ID="PASTE_HERE"            # Account Settings → Clerk API
CLICKBANK_CLIENT_SECRET="PASTE_HERE"        # Account Settings → Clerk API

# HopLink tracking IDs you created (comma-separated, optional)
CLICKBANK_TRACKING_IDS="TID1,TID2,TID3"

# =============================================================================
# AMAZON ASSOCIATES
# Navigate: https://affiliate-program.amazon.com/home/account/tag
# =============================================================================
AMAZON_ASSOCIATES_TAG="PASTE_HERE"

# =============================================================================
# STRIPE  (for Substack/Medium payouts)
# Navigate: https://dashboard.stripe.com/apikeys
# =============================================================================
STRIPE_PUBLISHABLE_KEY="PASTE_HERE"
STRIPE_SECRET_KEY="PASTE_HERE"

# =============================================================================
# SMTP  (for email automation if you want it)
# Gmail: smtp.gmail.com, port 587, your Gmail + App Password
# =============================================================================
SMTP_HOST="PASTE_HERE"
SMTP_PORT="587"
SMTP_USER="PASTE_HERE"
SMTP_PASS="PASTE_HERE"

# =============================================================================
# DONE? Save this file and run:
#   python tools/ingest_account_keys.py
# =============================================================================
