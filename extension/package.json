{
  "name": "orbitscribe-swarm",
  "displayName": "OrbitScribe",
  "description": "Agentic chatbot for VS Code — powered by local LLMs and cloud APIs",
  "version": "3.1.1",
  "publisher": "orbstudio",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onView:orbitscribe.splashView",
    "onCommand:orbitscribe.openSwarmPanel",
    "onCommand:orbitscribe.diagnoseVoiceBackend",
    "onCommand:orbitscribe.restartVoiceBackend",
    "onCommand:orbitscribe.activateMassSwarm",
    "onCommand:orbitscribe.openCommandViewport",
    "onCommand:orbitscribe.openJukebox",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "orbitscribe.openSwarmPanel",
        "title": "Open Chat Panel",
        "category": "OrbitScribe",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "orbitscribe.openSwarmPanelAsk",
        "title": "Ask Mode",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.openSwarmPanelPlan",
        "title": "Plan Mode",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.openSwarmPanelAgent",
        "title": "Agent Mode",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.openSwarmPanelSwarm",
        "title": "Multi-Agent",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.openCommandViewport",
        "title": "Open Command Viewport",
        "category": "OrbitScribe",
        "icon": "$(dashboard)"
      },
      {
        "command": "orbitscribe.openCommandDeck",
        "title": "Open Command Deck",
        "category": "OrbitScribe",
        "icon": "$(layout-panel-left)"
      },
      {
        "command": "orbitscribe.openJukebox",
        "title": "Open Infinite Jukebox",
        "category": "OrbitScribe",
        "icon": "$(play-circle)"
      },
      {
        "command": "orbitscribe.voiceInput",
        "title": "Voice Input",
        "category": "OrbitScribe",
        "icon": "$(mic)"
      },
      {
        "command": "orbitscribe.refreshAgents",
        "title": "Refresh Agents",
        "category": "OrbitScribe",
        "icon": "$(refresh)"
      },
      {
        "command": "orbitscribe.refreshFiles",
        "title": "Refresh Files",
        "category": "OrbitScribe",
        "icon": "$(refresh)"
      },
      {
        "command": "orbitscribe.diagnoseVoiceBackend",
        "title": "Diagnose Voice Backend",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.restartVoiceBackend",
        "title": "Restart Voice Backend",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.diagnoseSwarmBackend",
        "title": "Diagnose Backend",
        "category": "OrbitScribe"
      },
      {
        "command": "orbitscribe.compactContext",
        "title": "Compact Context",
        "category": "OrbitScribe",
        "icon": "$(fold)"
      },
      {
        "command": "orbitscribe.activateMassSwarm",
        "title": "Activate Multi-Agent",
        "category": "OrbitScribe",
        "icon": "$(rocket)"
      },
      {
        "command": "orbitscribe.reviewChanges",
        "title": "Review Agent Changes",
        "category": "OrbitScribe",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "orbitscribe.undoLastBatch",
        "title": "Undo Last Batch",
        "category": "OrbitScribe",
        "icon": "$(discard)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orbitscribe-swarm",
          "title": "OrbitScribe",
          "icon": "logo.svg"
        }
      ]
    },
    "views": {
      "orbitscribe-swarm": [
        {
          "id": "orbitscribe.splashView",
          "name": "OrbitScribe",
          "type": "webview"
        },
        {
          "id": "swarmAgents",
          "name": "Agents",
          "icon": "$(server)"
        },
        {
          "id": "swarmFiles",
          "name": "Context",
          "icon": "$(file-code)"
        }
      ]
    },
    "configuration": {
      "title": "OrbitScribe",
      "properties": {
        "orbitscribe.apiMode": {
          "type": "string",
          "default": "hybrid",
          "enum": ["local_only", "cloud_only", "hybrid"],
          "description": "API lockout mode: local_only forces Ollama/LM Studio, cloud_only forces Gemini/Copilot, hybrid auto-selects based on task"
        },
        "orbitscribe.backendPort": {
          "type": "number",
          "default": 58081,
          "description": "Port for the backend server"
        },
        "orbitscribe.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "orbitscribe.lmStudioUrl": {
          "type": "string",
          "default": "http://localhost:1234",
          "description": "LM Studio server URL"
        },
        "orbitscribe.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to Python executable. Leave empty to auto-detect."
        },
        "orbitscribe.voiceStartupMode": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "spawn", "terminal"],
          "description": "How to start the voice backend: auto detects, spawn launches directly, terminal opens in integrated terminal"
        },
        "orbitscribe.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "LLM temperature: 0 = focused/deterministic, 1 = very creative/random"
        },
        "orbitscribe.orchestratorModel": {
          "type": "string",
          "default": "",
          "description": "Default orchestrator model (e.g., claude-3-5-sonnet-20241022, gpt-4o, gemini-2.0-flash). Leave empty for auto."
        },
        "orbitscribe.subagentMode": {
          "type": "string",
          "default": "hybrid",
          "enum": ["cloud", "local", "hybrid"],
          "description": "Subagent spawning mode: cloud uses cloud LLMs, local uses Ollama/LM Studio, hybrid auto-selects"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}
